{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/changes-claims/layout,_N_T_/changes-claims/page,_N_T_/changes-claims"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/changes-claims/__PAGE__",
    "/changes-claims",
    "/_index",
    "/_head"
  ]
}